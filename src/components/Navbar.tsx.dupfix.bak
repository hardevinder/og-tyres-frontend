"use client";
"use client";

import { useEffect, useRef, useState, useMemo, useCallback } from "react";
import { useRouter } from "next/navigation";
import Link from "next/link";
import {
  ShoppingCart,
  User,
  Menu,
  X,
  ChevronDown,
  ChevronRight,
  Heart,
} from "lucide-react";
import { resolveImageUrl } from "@/utils/resolveImageUrl";
import { getCartApi, readSessionId } from "@/utils/cart"; // <-- ADDED

function getApiBase(): string {
  const env = (process.env.NEXT_PUBLIC_API_URL || "").trim();
  if (env) return env.replace(/\/$/, "");
  if (typeof window !== "undefined") {
    const loc = window.location.origin;
    if (loc.includes("localhost:3000"))
      return loc.replace(":3000", ":5000") + "/api";
    return loc + "/api";
  }
  return "";
}
const API = getApiBase();

interface UserInfo {
  id: number;
  name: string;
  email: string;
  isAdmin?: boolean;
}

interface Product {
  id: number;
  name: string;
  slug?: string;
  summary?: string | null;
  images?: Array<{ id?: number; url: string; alt?: string | null }>;
}

export default function Navbar() {
  const router = useRouter();
  const [isOpen, setIsOpen] = useState(false);
  const [isMegaOpen, setMegaOpen] = useState(false);
  const [dropdownOpen, setDropdownOpen] = useState(false);
  const [user, setUser] = useState<UserInfo | null>(null);
  const [products, setProducts] = useState<Product[]>([]);
  const [activeProduct, setActiveProduct] = useState<Product | null>(null);
  const [visible, setVisible] = useState(true);
  const [scrolled, setScrolled] = useState(false);
  const [isLoading, setIsLoading] = useState(true);

  // CART: live count
  const [cartCount, setCartCount] = useState<number>(0);

  const megaRef = useRef<HTMLDivElement | null>(null);
  const headerRef = useRef<HTMLElement | null>(null);
  const dropdownRef = useRef<HTMLDivElement | null>(null);
  const lastY = useRef(0);
  const ticking = useRef(false);

  const headerSpacerClass = "h-20";

  // Memoized API fetch
  const fetchProducts = useCallback(async () => {
    try {
      setIsLoading(true);
      const res = await fetch(`${API}/products`, { cache: "force-cache" });
      if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
      const json = await res.json();
      const arr = Array.isArray(json?.data)
        ? json.data
        : Array.isArray(json)
        ? json
        : [];
      setProducts(arr);
      if (arr.length > 0) setActiveProduct(arr[0]);
    } catch (err) {
      console.error("Navbar fetchProducts failed:", err);
    } finally {
      setIsLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchProducts();
  }, [fetchProducts]);

  // Auth helpers
  const readToken = useCallback((): string | null => {
    return (
      localStorage.getItem("accessToken") ||
      sessionStorage.getItem("accessToken") ||
      null
    );
  }, []);

  const notifyAuthChange = useCallback(() => {
    try {
      window.dispatchEvent(new Event("auth"));
      localStorage.setItem("auth_update", String(Date.now()));
    } catch {}
  }, []);

  const fetchUser = useCallback(async () => {
    const token = readToken();
    if (!token) {
      setUser(null);
      return;
    }
    try {
      const meUrl = API ? `${API}/auth/me` : "/api/auth/me";
      const res = await fetch(meUrl, {
        headers: { Authorization: `Bearer ${token}` },
        cache: "no-store",
      });
      if (!res.ok) {
        localStorage.removeItem("accessToken");
        sessionStorage.removeItem("accessToken");
        setUser(null);
        return;
      }
      const j = await res.json();
      const u = j?.user || j;
      if (u) {
        setUser({
          id: u.id,
          name: u.name,
          email: u.email,
          isAdmin: u.isAdmin,
        });
      } else {
        setUser(null);
      }
    } catch {
      setUser(null);
    }
  }, [readToken]);

  useEffect(() => {
    fetchUser();
  }, [fetchUser]);

  useEffect(() => {
    const onStorageEvent = () => fetchUser();
    const onAuthEvent = () => fetchUser();
    window.addEventListener("storage", onStorageEvent);
    window.addEventListener("auth", onAuthEvent);
    return () => {
      window.removeEventListener("storage", onStorageEvent);
      window.removeEventListener("auth", onAuthEvent);
    };
  }, [fetchUser]);

  // Debounced scroll effect
  useEffect(() => {
    let timeoutId: NodeJS.Timeout;
    const onScroll = () => {
      if (!ticking.current) {
        timeoutId = setTimeout(() => {
          const currentY = window.scrollY || window.pageYOffset;
          setVisible(currentY <= lastY.current || currentY < 40);
          setScrolled(currentY > 30);
          lastY.current = currentY <= 0 ? 0 : currentY;
          ticking.current = false;
        }, 100);
        ticking.current = true;
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => {
      window.removeEventListener("scroll", onScroll);
      clearTimeout(timeoutId);
    };
  }, []);

  // Click outside handler
  useEffect(() => {
    const onDocClick = (e: MouseEvent) => {
      const target = e.target as Node | null;
      if (megaRef.current && target && !megaRef.current.contains(target))
        setMegaOpen(false);
      if (isOpen && headerRef.current && target && !headerRef.current.contains(target)) {
        setIsOpen(false);
      }
      if (dropdownRef.current && target && !dropdownRef.current.contains(target))
        setDropdownOpen(false);
    };
    document.addEventListener("click", onDocClick);
    return () => document.removeEventListener("click", onDocClick);
  }, [isOpen]);

  const handleAccountClick = useCallback(() => {
    if (user) setDropdownOpen((s) => !s);
    else router.push("/login");
  }, [user, router]);

  const handleLogout = useCallback(async () => {
    try {
      const token = readToken();
      const logoutUrl = API ? `${API}/auth/logout` : "/api/auth/logout";
      if (token) {
        await fetch(logoutUrl, {
          method: "POST",
          headers: { Authorization: `Bearer ${token}` },
        });
      }
    } catch {
      // Silent catch
    } finally {
      localStorage.removeItem("accessToken");
      sessionStorage.removeItem("accessToken");
      notifyAuthChange();
      setUser(null);
      setDropdownOpen(false);
      router.push("/login");
    }
  }, [router, readToken, notifyAuthChange]);

  const goToDashboard = useCallback(() => {
    setDropdownOpen(false);
    router.push(user?.isAdmin ? "/admin" : "/account");
  }, [user, router]);

  const handleProductsClick = useCallback(() => {
    setMegaOpen(false);
    router.push("/products");
  }, [router]);

  // CART: load cart count on mount and expose event listeners
  useEffect(() => {
    let mounted = true;

    async function loadCount() {
      try {
        // try API first (requires GET /api/cart implemented)
        const json = await getCartApi().catch(() => null);
        if (!mounted) return;
        if (json && json.data && Array.isArray(json.data.items)) {
          const count = json.data.items.reduce((s: number, it: any) => s + (it.quantity || 0), 0);
          setCartCount(count);
          return;
        }
        // fallback: try to detect a sessionId (if no GET endpoint)
        const sid = readSessionId();
        if (!sid) {
          setCartCount(0);
        } else {
          // we don't have cart details; leave as 0 until add triggers update event
          setCartCount(0);
        }
      } catch (e) {
        console.error("Failed to load cart count", e);
      }
    }

    loadCount();

    // Update when other parts of app dispatch cart:update
    const onCartUpdate = (e: any) => {
      try {
        const detail = e?.detail;
        if (detail && detail.data && Array.isArray(detail.data.items)) {
          const c = detail.data.items.reduce((s: number, it: any) => s + (it.quantity || 0), 0);
          setCartCount(c);
          return;
        }
        // generic event — re-fetch
        loadCount();
      } catch {
        loadCount();
      }
    };

    const onAuth = () => {
      // after login/logout, refresh cart (merged or user cart)
      loadCount();
    };

    window.addEventListener("cart:update", onCartUpdate);
    window.addEventListener("auth", onAuth);

    return () => {
      mounted = false;
      window.removeEventListener("cart:update", onCartUpdate);
      window.removeEventListener("auth", onAuth);
    };
  }, []);

  // Memoized styles
  const navStyles = useMemo(
    () => ({
      header: `fixed left-0 right-0 z-50 transform transition-all duration-300 ease-in-out backdrop-blur-md ${
        visible ? "translate-y-0" : "-translate-y-full"
      } ${
        scrolled
          ? "bg-white/95 shadow-xl border-b border-green-100"
          : "bg-gradient-to-r from-green-50/90 to-emerald-50/90 shadow-lg"
      }`,
      textColor: scrolled ? "#14532d" : "#166534",
      logo: `relative transition-all duration-300 ${scrolled ? "scale-95" : "scale-100"}`,
      logoImg: `h-16 w-auto rounded-full shadow-md transition-all duration-300 group-hover:rotate-3 group-hover:shadow-lg ${scrolled ? "h-12" : "h-16"}`,
      megaMenu: `absolute left-1/2 top-full mt-2 -translate-x-1/2 w-[90vw] max-w-[1200px] bg-white/95 rounded-2xl shadow-2xl border border-green-100 z-50 transition-all duration-300 ease-out overflow-hidden ${
        isMegaOpen
          ? "opacity-100 visible translate-y-0 scale-100"
          : "opacity-0 invisible -translate-y-4 scale-95"
      }`,
      mobileMenu: `md:hidden bg-gradient-to-b from-green-50/90 to-emerald-50/90 border-t border-green-200/50 p-4 flex flex-col gap-2 text-lg font-semibold text-emerald-800 transition-all duration-300 ease-in-out ${
        isOpen ? "max-h-[800px] opacity-100" : "max-h-0 opacity-0"
      }`,
    }),
    [visible, scrolled, isMegaOpen, isOpen]
  );

  return (
    <>
      <style jsx global>{`
        /* Reduced scrollbar thickness for vertical (and horizontal) scrollbars.
           Using: width/height 6px for WebKit and 'thin' for Firefox.
           Targeting .custom-green-scrollbar so it only applies to your mega menu list. */
        .custom-green-scrollbar::-webkit-scrollbar {
          width: 6px;   /* vertical scrollbar thickness */
          height: 6px;  /* horizontal scrollbar thickness */
        }
        .custom-green-scrollbar::-webkit-scrollbar-track {
          background: #f0fdf4;
          border-radius: 999px;
        }
        .custom-green-scrollbar::-webkit-scrollbar-thumb {
          background: linear-gradient(to right, #10b981, #059669);
          border-radius: 999px;
        }
        .custom-green-scrollbar::-webkit-scrollbar-thumb:hover {
          background: linear-gradient(to right, #059669, #047857);
        }

        /* Firefox */
        .custom-green-scrollbar {
          scrollbar-width: thin; /* makes scrollbar thinner in Firefox */
          scrollbar-color: #10b981 #f0fdf4; /* thumb color then track color */
        }

        /* Optional: add a subtle inset to avoid thumb touching edge */
        .custom-green-scrollbar {
          padding-right: 2px;
        }
      `}</style>
      <header ref={headerRef} className={navStyles.header} aria-label="Main navigation">
        <div className="max-w-7xl mx-auto flex items-center justify-between px-4 py-3 md:py-2">
          {/* Logo */}
          <Link
            href="/"
            className="flex items-center gap-3 hover:opacity-90 transition-all duration-200 group"
            aria-label="Gagan Ayurveda Home"
          >
            <div className={navStyles.logo}>
              <img
                src="/logo.png"
                alt="Gagan Ayurveda Logo"
                className={navStyles.logoImg}
              />
              <div className="absolute -inset-1 bg-gradient-to-r from-green-400 to-emerald-500 rounded-full blur opacity-20 group-hover:opacity-30 transition-opacity" />
            </div>
            <span
              className={`text-2xl md:text-3xl font-extrabold tracking-tight bg-gradient-to-r from-green-700 to-emerald-800 bg-clip-text text-transparent transition-all ${scrolled ? "text-xl" : ""}`}
            >
              Gagan <span className="text-emerald-600">Ayurveda</span>
            </span>
          </Link>

          {/* Desktop nav */}
          <nav
            className="hidden md:flex gap-10 text-base font-semibold items-center"
            style={{ color: navStyles.textColor }}
            aria-label="Primary navigation"
          >
            <div
              className="relative"
              onMouseEnter={() => setMegaOpen(true)}
              onMouseLeave={() => setMegaOpen(false)}
              ref={megaRef}
            >
              <button
                type="button"
                onClick={handleProductsClick}
                className="flex items-center gap-1.5 hover:text-emerald-700 transition-all duration-200 group"
                aria-expanded={isMegaOpen}
                aria-controls="mega-menu"
              >
                Products <ChevronDown className="h-4 w-4 group-hover:rotate-180 transition-transform duration-300" />
              </button>

              {/* Mega menu */}
              <div
                id="mega-menu"
                className={navStyles.megaMenu}
                role="menu"
                aria-hidden={!isMegaOpen}
              >
                <div className="flex min-h-[400px] relative">
                  <div className="absolute inset-0 bg-gradient-to-br from-green-50 to-emerald-50 opacity-60" />
                  <div className="w-1/3 border-r border-green-200/50 py-6 custom-green-scrollbar overflow-y-auto overflow-x-hidden max-h-[80vh] relative z-10">
                    <h4 className="px-6 mb-4 text-lg font-bold text-green-900 tracking-tight">
                      Discover Our Collection
                    </h4>
                    <div className="flex flex-col px-2 space-y-2">
                      {isLoading ? (
                        <div className="animate-pulse px-6 py-3">Loading products...</div>
                      ) : products.length === 0 ? (
                        <div className="px-6 py-3 text-gray-600">No products available</div>
                      ) : (
                        products.slice(0, 20).map((p) => (
                          <button
                            key={p.id}
                            onMouseEnter={() => setActiveProduct(p)}
                            onClick={() => {
                              setMegaOpen(false);
                              router.push(`/products/${p.slug || p.id}`);
                            }}
                            className={`w-full flex justify-between items-center px-6 py-3 hover:bg-gradient-to-r hover:from-green-50 hover:to-emerald-50 transition-all duration-200 rounded-xl
                              ${
                                activeProduct?.id === p.id
                                  ? "bg-gradient-to-r from-emerald-100 to-green-100 font-semibold text-emerald-900 shadow-inner"
                                  : "text-gray-800 hover:shadow-md"
                              }`}
                            role="menuitem"
                          >
                            <span className="truncate font-medium">{p.name}</span>
                            <ChevronRight
                              className={`h-5 w-5 text-green-500 transition-transform ${
                                activeProduct?.id === p.id ? "translate-x-1" : ""
                              }`}
                            />
                          </button>
                        ))
                      )}
                    </div>
                    {products.length > 20 && (
                      <Link
                        href="/products"
                        className="block px-6 py-3 text-emerald-800 font-semibold hover:underline flex items-center gap-2 transition-all duration-200"
                        onClick={() => setMegaOpen(false)}
                        role="menuitem"
                      >
                        View All Products <ChevronRight className="h-5 w-5" />
                      </Link>
                    )}
                  </div>
                  <div className="w-2/3 p-8 flex flex-col items-center justify-center relative z-10">
                    {activeProduct ? (
                      <>
                        <div className="relative group w-full max-w-md h-72 bg-white rounded-2xl shadow-xl overflow-hidden">
                          <img
                            src={
                              activeProduct.images?.[0]?.url
                                ? resolveImageUrl(activeProduct.images[0].url)
                                : "/placeholder.png"
                            }
                            alt={activeProduct.name}
                            className="w-full h-full object-contain p-6 transition-transform duration-300 group-hover:scale-105 group-hover:shadow-2xl"
                          />
                          <button
                            className="absolute -top-2 -right-2 bg-emerald-600 text-white p-2 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                            aria-label="Add to wishlist"
                          >
                            <Heart className="h-4 w-4 fill-current" />
                          </button>
                        </div>
                        <h3 className="mt-6 text-2xl font-bold text-emerald-900 text-center tracking-tight">
                          {activeProduct.name}
                        </h3>
                        {activeProduct.summary && (
                          <p className="mt-3 text-gray-700 text-base text-center line-clamp-4 leading-relaxed max-w-md font-light">
                            {activeProduct.summary}
                          </p>
                        )}
                        <Link
                          href={`/products/${activeProduct.slug || activeProduct.id}`}
                          className="mt-6 inline-flex items-center gap-2 bg-gradient-to-r from-emerald-700 to-green-700 text-white px-6 py-3 rounded-xl hover:from-emerald-800 hover:to-green-800 transition-all duration-200 shadow-lg hover:shadow-2xl transform hover:-translate-y-1"
                          role="menuitem"
                        >
                          Explore Now <ChevronRight className="h-4 w-4" />
                        </Link>
                      </>
                    ) : (
                      <div className="text-center animate-pulse">
                        <p className="text-gray-600 text-lg font-medium">
                          {isLoading ? "Loading..." : "Hover over a product to preview"}
                        </p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <Link
              href="/features"
              className="hover:text-emerald-700 transition-all duration-200 group relative"
              role="menuitem"
            >
              Features
              <span className="absolute bottom-0 left-0 w-0 h-0.5 bg-emerald-600 transition-all duration-300 group-hover:w-full" />
            </Link>
            <Link
              href="/contact"
              className="hover:text-emerald-700 transition-all duration-200 group relative"
              role="menuitem"
            >
              Contact
              <span className="absolute bottom-0 left-0 w-0 h-0.5 bg-emerald-600 transition-all duration-300 group-hover:w-full" />
            </Link>
            <Link
              href="/blogs"
              className="hover:text-emerald-700 transition-all duration-200 group relative"
              role="menuitem"
            >
              Blogs
              <span className="absolute bottom-0 left-0 w-0 h-0.5 bg-emerald-600 transition-all duration-300 group-hover:w-full" />
            </Link>
          </nav>

          {/* Right icons */}
          <div
            className="flex items-center gap-3 md:gap-4 relative"
            style={{ color: navStyles.textColor }}
            aria-label="User actions"
          >
            <Link
              href="/wishlist"
              className="relative p-1 rounded-full hover:bg-green-50/50 transition-all duration-200"
              aria-label="Wishlist"
            >
              <Heart className="h-5 w-5 hover:text-emerald-700 transition-transform duration-200 hover:scale-110" />
            </Link>

            <Link
              href="/cart"
              className="relative p-1 rounded-full hover:bg-green-50/50 transition-all duration-200"
              aria-label={`Shopping cart with ${cartCount} items`}
            >
              <ShoppingCart className="h-5 w-5 hover:text-emerald-700 transition-transform duration-200 hover:scale-110" />
              <span className="absolute -top-1 -right-1 bg-emerald-700 text-white text-xs px-1.5 py-0.5 rounded-full min-w-[18px] flex items-center justify-center shadow-sm">
                {cartCount}
              </span>
            </Link>

            {/* Account */}
            <div className="relative" ref={dropdownRef}>
              {user ? (
                <button
                  onClick={handleAccountClick}
                  className="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-gradient-to-r hover:from-green-50 hover:to-emerald-50 transition-all duration-200"
                  aria-expanded={dropdownOpen}
                  aria-controls="account-menu"
                >
                  <div className="h-8 w-8 rounded-full bg-emerald-100 flex items-center justify-center">
                    <User className="h-4 w-4 text-emerald-700" />
                  </div>
                  <span className="text-sm font-semibold text-gray-800 hidden md:block">
                    {user.name}
                  </span>
                  <ChevronDown
                    className={`h-4 w-4 transition-transform duration-200 ${
                      dropdownOpen ? "rotate-180" : ""
                    }`}
                  />
                </button>
              ) : (
                <button
                  onClick={handleAccountClick}
                  className="p-1 rounded-full hover:bg-green-50/50 transition-all duration-200"
                  aria-label="Log in"
                >
                  <User className="h-5 w-5 hover:text-emerald-700 transition-transform duration-200 hover:scale-110" />
                </button>
              )}
              {user && dropdownOpen && (
                <div
                  id="account-menu"
                  className="absolute right-0 mt-2 w-48 bg-white/95 border border-green-100/50 rounded-xl shadow-2xl z-50 overflow-hidden"
                  role="menu"
                  aria-hidden={!dropdownOpen}
                >
                  <div className="py-1 bg-gradient-to-b from-green-50/80 to-white">
                    <button
                      onClick={goToDashboard}
                      className="w-full text-left px-4 py-3 text-sm font-medium text-gray-800 hover:bg-emerald-50/80 flex items-center gap-3 transition-all duration-200"
                      role="menuitem"
                    >
                      <User className="h-4 w-4 text-emerald-600" />
                      Dashboard
                    </button>
                    <Link
                      href="/profile"
                      className="block px-4 py-3 text-sm font-medium text-gray-800 hover:bg-emerald-50/80 transition-all duration-200 flex items-center gap-3"
                      role="menuitem"
                    >
                      <Heart className="h-4 w-4 text-emerald-600" />
                      Profile
                    </Link>
                    <div className="border-t border-green-100/50 my-1" />
                    <button
                      onClick={handleLogout}
                      className="w-full text-left px-4 py-3 text-sm font-medium text-red-600 hover:bg-red-50/80 flex items-center gap-3 transition-all duration-200"
                      role="menuitem"
                    >
                      <X className="h-4 w-4 text-red-600" />
                      Logout
                    </button>
                  </div>
                </div>
              )}
            </div>

            <button
              className="md:hidden p-1 rounded-full hover:bg-green-50/50 transition-all duration-200"
              onClick={() => setIsOpen(!isOpen)}
              aria-label={isOpen ? "Close menu" : "Open menu"}
              aria-expanded={isOpen}
              aria-controls="mobile-menu"
            >
              {isOpen ? <X className="h-6 w-6" /> : <Menu className="h-6 w-6" />}
            </button>
          </div>
        </div>

        {/* Mobile menu */}
        <div id="mobile-menu" className={navStyles.mobileMenu} role="menu" aria-hidden={!isOpen}>
          <Link
            href="/products"
            onClick={() => setIsOpen(false)}
            className="flex items-center justify-between py-3 px-3 rounded-xl hover:bg-emerald-100/80 transition-all duration-200"
            role="menuitem"
          >
            <span>Products</span>
            <ChevronRight className="h-5 w-5 text-emerald-600" />
          </Link>
          <Link
            href="/features"
            onClick={() => setIsOpen(false)}
            className="py-3 px-3 rounded-xl hover:bg-emerald-100/80 transition-all duration-200 flex items-center gap-3"
            role="menuitem"
          >
            <span>Features</span>
          </Link>
          <Link
            href="/contact"
            onClick={() => setIsOpen(false)}
            className="py-3 px-3 rounded-xl hover:bg-emerald-100/80 transition-all duration-200 flex items-center gap-3"
            role="menuitem"
          >
            <span>Contact</span>
          </Link>
          <Link
            href="/blogs"
            onClick={() => setIsOpen(false)}
            className="py-3 px-3 rounded-xl hover:bg-emerald-100/80 transition-all duration-200 flex items-center gap-3"
            role="menuitem"
          >
            <span>Blogs</span>
          </Link>
        </div>
      </header>

      <div className={headerSpacerClass} aria-hidden="true" />
    </>
  );
}
