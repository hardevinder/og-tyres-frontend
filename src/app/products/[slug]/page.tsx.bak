// src/app/products/[slug]/page.tsx
import React from "react";
import { notFound } from "next/navigation";
import { resolveImageUrl } from "@/utils/resolveImageUrl";
import BreadcrumbBanner from "@/components/BreadcrumbBanner";
import AddToCartClient from "@/components/AddToCartClient"; // <-- client wrapper

type ParamsLike = { slug: string } | Promise<{ slug: string }>;

function originForThisPage(): string {
  const pageEnv = (process.env.NEXT_PUBLIC_PRODUCTS_API ?? "").trim();
  const globalEnv = (process.env.NEXT_PUBLIC_API_URL ?? "").trim();
  const raw = pageEnv || globalEnv || "http://localhost:5000";
  return raw.replace(/\/+$/u, "").replace(/\/api$/u, "");
}

async function fetchProductBySlug(slug: string) {
  const origin = originForThisPage();
  const url = `${origin}/api/products`;
  try {
    const res = await fetch(url, { cache: "no-store" });
    if (!res.ok) {
      console.error("fetchProductBySlug failed", res.status, await res.text());
      return null;
    }
    const json = await res.json();
    const arr: any[] = Array.isArray(json?.data) ? json.data : Array.isArray(json) ? json : [];
    return arr.find((p) => String(p.slug) === String(slug) || String(p.id) === String(slug)) ?? null;
  } catch (err) {
    console.error("fetchProductBySlug error", err);
    return null;
  }
}

export default async function ProductPage({ params }: { params: ParamsLike }) {
  const { slug } = (await params) as { slug: string };
  const product = await fetchProductBySlug(slug);

  if (!product) return notFound();

  const priceRaw = product.variants?.[0]?.salePrice ?? product.variants?.[0]?.price ?? null;
  const price = priceRaw ? (typeof priceRaw === "string" ? parseFloat(priceRaw) : priceRaw) : null;
  const rating = 4.5; // Placeholder

  const variants: any[] = Array.isArray(product.variants) ? product.variants : [];

  return (
    <>
      <BreadcrumbBanner
        title={product.name}
        breadcrumbs={[
          { label: "Home", href: "/" },
          { label: "Products", href: "/products" },
          { label: product.name },
        ]}
        background="/products-banner.jpg"
      />

      <div className="px-6 py-16 max-w-7xl mx-auto bg-gray-50">
        <div className="flex flex-col md:flex-row gap-12">
          {/* Images */}
          <div className="md:w-1/2">
            <div className="w-full h-[900px] bg-gray-100 rounded-xl overflow-hidden shadow-lg transition-transform duration-300 hover:scale-[1.02]">
              {product.images?.[0] ? (
                <img
                  src={resolveImageUrl(product.images[0].url)}
                  alt={product.images[0].alt ?? product.name}
                  className="w-full h-full object-cover"
                />
              ) : (
                <div className="w-full h-full flex items-center justify-center text-gray-400 bg-gray-200">No image</div>
              )}
            </div>
            <div className="flex gap-3 mt-4 flex-wrap justify-center">
              {product.images?.map((img: any) => (
                <div
                  key={img.id}
                  className="w-24 h-24 rounded-lg overflow-hidden border border-gray-200 hover:border-emerald-500 transition-colors cursor-pointer"
                >
                  <img src={resolveImageUrl(img.url)} alt={img.alt ?? product.name} className="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          </div>

          {/* Info */}
          <div className="md:w-1/2">
            <h1 className="text-4xl font-bold text-gray-800 mb-3">{product.name}</h1>

            <div className="flex items-center gap-2 mb-4">
              <div className="flex">
                {[...Array(5)].map((_, i) => (
                  <svg key={i} className={`w-5 h-5 ${i < Math.floor(rating) ? "text-yellow-400" : "text-gray-300"}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.97a1 1 0 00.95.69h4.18c.969 0 1.371 1.24.588 1.81l-3.39 2.46a1 1 0 00-.364 1.118l1.287 3.97c.3.921-.755 1.688-1.54 1.118l-3.39-2.46a1 1 0 00-1.175 0l-3.39 2.46c-.784.57-1.838-.197-1.54-1.118l1.287-3.97a1 1 0 00-.364-1.118L2.27 9.397c-.784-.57-.38-1.81.588-1.81h4.18a1 1 0 00.95-.69l1.286-3.97z" />
                  </svg>
                ))}
              </div>
              <span className="text-sm text-gray-600">({rating} / 5)</span>
            </div>

            <div className="text-emerald-600 font-semibold text-3xl mb-4">{price ? `₹${Number(price).toFixed(2)}` : "Price on request"}</div>
            <div className="text-sm text-gray-500 mb-6">{product.category?.name}</div>

            {/* Client add-to-cart area */}
            <div className="mb-8">
              <AddToCartClient variants={variants} />
            </div>

            <a href="/products" className="inline-block px-8 py-3 rounded-lg bg-white border border-gray-300 text-gray-700 font-medium hover:bg-gray-100 transition-all duration-300">Back to products</a>

            {product.summary && <p className="mt-8 text-gray-600 leading-relaxed text-lg">{product.summary}</p>}
            {product.description && <div className="prose mt-8 text-gray-600 max-w-none" dangerouslySetInnerHTML={{ __html: product.description }} />}
          </div>
        </div>
      </div>
    </>
  );
}
