"use client";

import React, { useEffect, useState } from "react";
import dynamic from "next/dynamic";
import { useSearchParams, useRouter, useParams } from "next/navigation";
import { getGuestTokenForOrder } from "@/utils/checkout";

// same as CartPage: client-side import to avoid SSR issues
const BreadcrumbBanner = dynamic(() => import("@/components/BreadcrumbBanner"), { ssr: false });

type Order = any;

function formatMoney(v: string | number | null | undefined) {
  if (v == null) return "—";
  const n = typeof v === "string" ? parseFloat(v) : Number(v);
  if (!isFinite(n)) return "—";
  return new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR" }).format(n);
}

export default function OrderPage() {
  const params = useParams() as { orderNumber?: string } | null;
  const orderNumber = params?.orderNumber ?? "";
  const searchParams = useSearchParams();
  const router = useRouter();

  const [order, setOrder] = useState<Order | null>(null);
  const [loading, setLoading] = useState(true);
  const [err, setErr] = useState<string | null>(null);

  useEffect(() => {
    let canceled = false;
    async function load() {
      setLoading(true);
      setErr(null);

      try {
        let token = searchParams?.get("token") ?? null;
        if (!token) token = getGuestTokenForOrder(orderNumber);

        const apiBase =
          (process.env.NEXT_PUBLIC_API_URL || "").replace(/\/api\/?$/i, "") ||
          window.location.origin;
        const url = `${apiBase}/api/orders/${encodeURIComponent(orderNumber)}${
          token ? `?token=${encodeURIComponent(token)}` : ""
        }`;

        const res = await fetch(url, { credentials: "include" });
        if (!res.ok) {
          const j = await res.json().catch(() => ({ error: "Failed to fetch order" }));
          throw new Error(j?.error || `Status ${res.status}`);
        }
        const j = await res.json();
        const data = j?.data ?? j;
        if (!canceled) setOrder(data);
      } catch (e: any) {
        if (!canceled) setErr(String(e?.message ?? e));
      } finally {
        if (!canceled) setLoading(false);
      }
    }

    if (!orderNumber) {
      setErr("Missing order number in URL");
      setLoading(false);
      return;
    }

    load();
    return () => {
      canceled = true;
    };
  }, [orderNumber, searchParams]);

  const banner = (
    <BreadcrumbBanner
      title={`Order ${orderNumber ? `#${orderNumber}` : "Details"}`}
      breadcrumbs={[
        { label: "Home", href: "/" },
        { label: "Orders", href: "/orders" },
        { label: orderNumber ? `#${orderNumber}` : "Order" },
      ]}
      background="/products-banner.jpg" // ✅ same as Cart
    />
  );

  if (loading) {
    return (
      <>
        {banner}
        <div className="min-h-[50vh] flex items-center justify-center p-8">
          <div className="flex flex-col items-center">
            <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-emerald-600" />
            <div className="mt-4 text-gray-600 font-medium">Loading order…</div>
          </div>
        </div>
      </>
    );
  }

  if (err) {
    return (
      <>
        {banner}
        <div className="p-8 text-red-600 max-w-4xl mx-auto">{`Error: ${err}`}</div>
      </>
    );
  }

  if (!order) {
    return (
      <>
        {banner}
        <div className="p-8 max-w-4xl mx-auto">Order not found</div>
      </>
    );
  }

  const ship = order.shippingAddress ?? {};
  const addrLine1 =
    ship.line1 ?? ship.line_1 ?? ship.addressLine1 ?? ship.address_1 ?? null;
  const addrLine2 =
    ship.line2 ?? ship.line_2 ?? ship.addressLine2 ?? ship.address_2 ?? null;
  const city = ship.city ?? null;
  const state = ship.state ?? null;
  const postalCode =
    ship.postalCode ?? ship.postal_code ?? ship.postal ?? null;
  const country = ship.country ?? null;
  const shipPhone = ship.phone ?? null;
  const customerName = order.customerName ?? order.customer_name ?? "Customer";
  const customerEmail = order.customerEmail ?? order.customer_email ?? null;
  const customerPhone = order.customerPhone ?? order.customer_phone ?? null;

  const subtotal = order.subtotal != null ? Number(order.subtotal) : null;
  const shipping = order.shipping != null ? Number(order.shipping) : 0;
  const tax = order.tax != null ? Number(order.tax) : 0;
  const discount = order.discount != null ? Number(order.discount) : 0;
  const grandTotal =
    order.grandTotal != null
      ? Number(order.grandTotal)
      : subtotal != null
      ? subtotal + (shipping ?? 0) + (tax ?? 0) - (discount ?? 0)
      : null;

  return (
    <>
      {banner}

      <div className="max-w-4xl mx-auto p-6">
        <div className="mb-6 flex items-start justify-between gap-6">
          <div>
            <h1 className="text-2xl font-bold mb-1">
              Order {order.orderNumber ?? orderNumber}
            </h1>
            <div className="text-sm text-gray-600">
              Placed:{" "}
              {order.createdAt
                ? new Date(order.createdAt).toLocaleString()
                : "—"}
            </div>
          </div>

          <div className="text-right">
            <div className="text-sm text-gray-500">Payment</div>
            <div className="font-semibold">
              {String(order.paymentMethod ?? "—").toUpperCase()}
            </div>
            <div
              className={`mt-1 inline-block px-3 py-1 text-xs rounded-full ${
                order.paymentStatus === "paid"
                  ? "bg-emerald-100 text-emerald-700"
                  : "bg-yellow-50 text-yellow-800"
              }`}
            >
              {order.paymentStatus ?? "pending"}
            </div>
          </div>
        </div>

        {/* Customer & Shipping */}
        <section className="mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div className="bg-white rounded-lg p-4 shadow-sm">
            <h2 className="font-semibold mb-2">Customer</h2>
            <div>
              <strong>Name:</strong> {customerName}
            </div>
            <div>
              <strong>Email:</strong> {customerEmail ?? "—"}
            </div>
            <div>
              <strong>Phone:</strong> {customerPhone ?? "—"}
            </div>
          </div>

          <div className="bg-white rounded-lg p-4 shadow-sm">
            <h2 className="font-semibold mb-2">Shipping Address</h2>
            <div>{addrLine1 ?? "—"}</div>
            {addrLine2 && <div>{addrLine2}</div>}
            <div>
              {city ? `${city}${state ? ", " + state : ""}` : state ?? "—"}
            </div>
            <div>{postalCode ? `PIN: ${postalCode}` : "PIN: —"}</div>
            <div>{country ? `Country: ${country}` : "Country: —"}</div>
            <div className="mt-2 text-sm text-gray-600">
              <strong>Contact:</strong> {shipPhone ?? "—"}
            </div>
          </div>
        </section>

        {/* Items */}
        <section className="mb-6">
          <h2 className="text-lg font-semibold mb-3">Items</h2>
          <ul className="space-y-3">
            {(order.items || []).map((it: any) => {
              const unitPrice = it.price != null ? Number(it.price) : null;
              const lineTotal =
                it.total != null
                  ? Number(it.total)
                  : unitPrice != null && it.quantity
                  ? unitPrice * Number(it.quantity)
                  : null;
              return (
                <li
                  key={it.id ?? `${it.variantId}-${it.productName}`}
                  className="bg-white rounded-lg p-4 shadow-sm"
                >
                  <div className="flex items-start justify-between gap-4">
                    <div className="flex-1 min-w-0">
                      <div className="font-semibold text-gray-800">
                        {it.productName ?? "Product"}
                      </div>
                      <div className="text-sm text-gray-500 mt-1">
                        Variant ID: {String(it.variantId ?? "—")}
                      </div>
                      {it.sku && (
                        <div className="text-sm text-gray-500">SKU: {it.sku}</div>
                      )}
                      {it.productMeta && (
                        <div className="text-sm text-gray-500 mt-1">
                          {String(it.productMeta)}
                        </div>
                      )}
                    </div>

                    <div className="text-right">
                      <div className="text-sm text-gray-600">Unit</div>
                      <div className="font-medium">{formatMoney(unitPrice)}</div>
                      <div className="text-sm text-gray-600 mt-2">Qty</div>
                      <div className="font-medium">{it.quantity}</div>
                      <div className="text-sm text-gray-600 mt-2">Line</div>
                      <div className="text-sm font-semibold">
                        {formatMoney(lineTotal)}
                      </div>
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        </section>

        {/* Totals */}
        <section className="mb-6 bg-white rounded-lg p-4 shadow-sm">
          <h3 className="font-semibold mb-3">Order Summary</h3>
          <div className="grid grid-cols-2 gap-2 text-sm text-gray-700">
            <div>Subtotal</div>
            <div className="text-right">{formatMoney(subtotal)}</div>

            <div>Shipping</div>
            <div className="text-right">{formatMoney(shipping)}</div>

            <div>Tax</div>
            <div className="text-right">{formatMoney(tax)}</div>

            <div>Discount</div>
            <div className="text-right">-{formatMoney(discount)}</div>

            <div className="text-lg font-semibold pt-2">Grand Total</div>
            <div className="text-lg font-semibold text-right pt-2">
              {formatMoney(grandTotal)}
            </div>
          </div>
        </section>

        {/* Applied shipping rule (if any) */}
        {order.appliedShippingRule && (
          <section className="mb-6 bg-white rounded-lg p-4 shadow-sm">
            <h3 className="font-semibold mb-2">Applied Shipping Rule</h3>
            <div>
              <strong>
                {order.appliedShippingRule.name ?? "Shipping rule"}
              </strong>
            </div>
            <div className="text-sm text-gray-600">
              Pincode range: {order.appliedShippingRule.pincodeFrom} —{" "}
              {order.appliedShippingRule.pincodeTo}
            </div>
            <div className="text-sm text-gray-600">
              Charge: {order.appliedShippingRule.charge}
            </div>
            {order.appliedShippingRule.minOrderValue && (
              <div className="text-sm text-gray-600">
                Free over: {order.appliedShippingRule.minOrderValue}
              </div>
            )}
          </section>
        )}

        {/* Meta / actions */}
        <section className="flex gap-3">
          <button
            onClick={() => router.push("/")}
            className="px-4 py-2 border rounded bg-white hover:shadow"
          >
            Continue shopping
          </button>
          <button
            onClick={() =>
              navigator.clipboard?.writeText(window.location.href)
            }
            className="px-4 py-2 border rounded bg-white hover:shadow"
          >
            Copy order link
          </button>
        </section>
      </div>
    </>
  );
}
